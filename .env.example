APP_NAME=WorldPulse24
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Admin email — receives contact form submissions + failure alerts
ADMIN_EMAIL=admin@yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=news_paper
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — set MAIL_MAILER=smtp for production
# Contact form submissions and newsletter welcome emails require working mail
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── OpenRouter ─────────────────────────────────────────────────────────────
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model Selection
SEARCH_MODEL=google/gemini-2.5-flash
TEXT_MODEL=openai/gpt-4o-mini
IMAGE_MODEL=bytedance/sdxl-lightning-4step

# ─── Unsplash (optional — free tier: 50 req/hr) ─────────────────────────────
# Get key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# ─── Google Search Console Indexing API (optional) ───────────────────────────
# Setup: https://developers.google.com/search/apis/indexing-api/v3/quickstart
# 1. Create service account in Google Cloud Console
# 2. Enable Indexing API
# 3. Add service account email as owner in Search Console
# 4. Download JSON key — copy values below
GOOGLE_INDEXING_API_KEY=
GOOGLE_INDEXING_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Paste private key as single line with \n for newlines:
GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"

# ─── News Automation ─────────────────────────────────────────────────────────
# Runs every 2 hours — 5 articles per run = 60 articles/day max
NEWS_MAX_ARTICLES_PER_RUN=5
NEWS_DEFAULT_PUBLISH=true
